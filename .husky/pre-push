#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 Running pre-push checks..."

# 1. Lint
echo "📋 Checking lint..."
npm run lint:fix
if [ $? -ne 0 ]; then
  echo "❌ Lint failed. Fix errors and try again."
  exit 1
fi

# 2. Format
echo "✨ Checking format..."
npm run format
if [ $? -ne 0 ]; then
  echo "❌ Format failed. Fix formatting and try again."
  exit 1
fi

# 3. Tests
echo "🧪 Running tests..."
npm test -- --passWithNoTests
if [ $? -ne 0 ]; then
  echo "❌ Tests failed. Fix tests and try again."
  exit 1
fi

# 4. Security audit
echo "🔒 Running security audit..."
npm audit --audit-level=high --omit=dev
if [ $? -ne 0 ]; then
  echo "⚠️  Security audit found high-severity vulnerabilities."
  echo "Run: npm audit fix --legacy-peer-deps"
  exit 1
fi

echo "✅ All pre-push checks passed! Proceeding with push."
